    "@fastify/type-provider-json-schema-to-ts": "^5.0.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-node": "^11.1.0",
    "fastify-plugin": "^5.1.0",
